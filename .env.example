# Copy to `.env` and fill in values. Never commit `.env`.

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO

# SEC EDGAR requires an identifying User-Agent with contact info.
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT="AlphaMind Research your-email@example.com"

# Primary datastore (Postgres with the pgvector extension).
DATABASE_URL="postgresql+asyncpg://alphamind:alphamind@localhost:5432/alphamind"

# Cache and rate-limit coordination.
REDIS_URL="redis://localhost:6379/0"

# Object storage for filing bodies. Only 'local' is implemented today.
# STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=./data/storage

# Embedder backend. 'deterministic' is a hash-seeded RNG stub for dev/tests.
# 'gemini' calls Google's free gemini-embedding-001 endpoint and requires
# GOOGLE_API_KEY (get one at https://aistudio.google.com/app/apikey).
# EMBEDDING_BACKEND=deterministic
# GOOGLE_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Reranker backend. 'deterministic' is a Jaccard-overlap stub (no deps).
# 'cross_encoder' wraps sentence-transformers — requires the 'rerank' extra
# (`uv sync --extra rerank`) which pulls torch (~1GB+).
# RERANKER_BACKEND=deterministic
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# LLM provider for the agent layer. 'echo' is an offline stub; 'anthropic'
# calls the real API and requires ANTHROPIC_API_KEY.
# LLM_BACKEND=echo
# LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=sk-ant-...

# LLM providers — populated in later phases.
# OPENAI_API_KEY=

# Market data — populated in later phases.
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# NEWSAPI_KEY=
