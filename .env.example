# Copy to `.env` and fill in values. Never commit `.env`.

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO

# SEC EDGAR requires an identifying User-Agent with contact info.
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT="AlphaMind Research your-email@example.com"

# Primary datastore (Postgres with the pgvector extension).
DATABASE_URL="postgresql+asyncpg://alphamind:alphamind@localhost:5432/alphamind"

# Cache and rate-limit coordination.
REDIS_URL="redis://localhost:6379/0"

# Object storage for filing bodies. Only 'local' is implemented today.
# STORAGE_BACKEND=local
# STORAGE_LOCAL_PATH=./data/storage

# Embedder backend. 'deterministic' is hash-based and model-free (good for
# tests and dev). 'gemini' calls Google's free text-embedding-004 endpoint;
# set GOOGLE_API_KEY to a key from https://aistudio.google.com/app/apikey.
# EMBEDDER_BACKEND=deterministic
# EMBEDDER_DIMENSION=768
# GOOGLE_API_KEY=
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# LLM providers — populated in later phases.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Market data — populated in later phases.
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# NEWSAPI_KEY=
