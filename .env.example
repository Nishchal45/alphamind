# Copy to `.env` and fill in values. Never commit `.env`.

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO

# SEC EDGAR requires an identifying User-Agent with contact info.
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT="AlphaMind Research your-email@example.com"

# Primary datastore (Postgres with the pgvector extension).
DATABASE_URL="postgresql+asyncpg://alphamind:alphamind@localhost:5432/alphamind"

# Cache and rate-limit coordination.
REDIS_URL="redis://localhost:6379/0"

# LLM providers — populated in later phases.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Market data — populated in later phases.
# ALPACA_API_KEY=
# ALPACA_API_SECRET=
# NEWSAPI_KEY=
